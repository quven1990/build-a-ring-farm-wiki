# Canonical production URL (sitemap, robots.txt, Open Graph, canonical links)
# Use https://buildaring.online even locally if you test OG/Twitter previews in meta debuggers.
NEXT_PUBLIC_SITE_URL=https://buildaring.online

# Optional Twitter @handle for twitter:site on share cards (e.g. @YourWikiHandle)
# NEXT_PUBLIC_TWITTER_SITE=@buildaringonline

# Google AdSense — create display ad units in AdSense dashboard, then paste slot IDs:
# NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=0000000000
# NEXT_PUBLIC_ADSENSE_SLOT_HOME=0000000000
# Until set, ad placeholders are hidden (script + ads.txt still active for site verification).

# Plausible: Shipsolo-hosted snippet is wired in app/layout.tsx (<head>), not env-driven.

# Local dev on macOS < 13.5: Cloudflare workerd is auto-skipped in next.config.mjs.
# Force on (may crash): OPENNEXT_CLOUDFLARE_DEV=1
# Force off: OPENNEXT_CLOUDFLARE_DEV=0
