# Canonical production URL (sitemap, robots.txt, Open Graph, canonical links)
NEXT_PUBLIC_SITE_URL=https://buildaring.online

# Plausible Analytics — https://www.npmjs.com/package/@plausible-analytics/tracker
# Domain must match your site in Plausible dashboard (defaults to hostname of SITE_URL)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=buildaring.online
# Optional: proxy endpoint — https://plausible.io/docs/proxy/introduction
# NEXT_PUBLIC_PLAUSIBLE_ENDPOINT=https://plausible.io/api/event
# Set to true to send events from localhost during development
# NEXT_PUBLIC_PLAUSIBLE_CAPTURE_LOCALHOST=false
# Set to true to disable Plausible entirely
# NEXT_PUBLIC_PLAUSIBLE_DISABLED=false
