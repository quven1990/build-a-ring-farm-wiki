# Canonical production URL (sitemap, robots.txt, Open Graph, canonical links)
NEXT_PUBLIC_SITE_URL=https://buildaring.online

# Google AdSense — create display ad units in AdSense dashboard, then paste slot IDs:
# NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=0000000000
# NEXT_PUBLIC_ADSENSE_SLOT_HOME=0000000000
# Until set, ad placeholders are hidden (script + ads.txt still active for site verification).

# Plausible Analytics — https://www.npmjs.com/package/@plausible-analytics/tracker
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=buildaring.online
# NEXT_PUBLIC_PLAUSIBLE_DISABLED=false
